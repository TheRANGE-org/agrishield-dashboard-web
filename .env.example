# ── Local development ──────────────────────────────────────────────────────────
# Leave empty so Vite's dev proxy handles /api/* → backend (no CORS issues).
# The proxy target defaults to the Cloud Run URL in vite.config.ts.
VITE_API_BASE_URL=

# ── Production (CF Pages build) ────────────────────────────────────────────────
# Set to the real API domain. The frontend will call this URL directly;
# CF Access handles auth at that domain.
# VITE_API_BASE_URL=https://agrishield-api.landmanager.io
